<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unisa.torneo.view.InterfacciaUtente"
            prefHeight="760.0" prefWidth="1120.0" styleClass="app-root">
    <top>
        <VBox spacing="0.0">
            <MenuBar styleClass="app-menu">
                <menus>
                    <Menu text="File">
                        <items>
                            <MenuItem text="Carica archivio..." onAction="#handleCaricaArchivio"/>
                            <MenuItem text="Salva archivio..." onAction="#handleSalvaArchivio"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Esci" onAction="#handleEsci"/>
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <VBox spacing="14.0" styleClass="hero-panel">
                <padding>
                    <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                </padding>
                <VBox spacing="6.0">
                    <Label styleClass="page-title" text="Gestione torneo di calcio a 5"/>
                    <Label styleClass="page-subtitle"
                           text="Gestisci squadre, partite e archivio del torneo con una GUI JavaFX coerente con la struttura attuale del progetto." wrapText="true"/>
                </VBox>

                <HBox spacing="14.0">
                    <children>
                        <VBox spacing="6.0" styleClass="stat-card">
                            <Label styleClass="stat-title" text="Squadre registrate"/>
                            <Label fx:id="totaleSquadreLabel" styleClass="stat-value" text="0"/>
                        </VBox>
                        <VBox spacing="6.0" styleClass="stat-card">
                            <Label styleClass="stat-title" text="Partite registrate"/>
                            <Label fx:id="totalePartiteLabel" styleClass="stat-value" text="0"/>
                        </VBox>
                        <VBox spacing="6.0" styleClass="stat-card">
                            <Label styleClass="stat-title" text="Capolista attuale"/>
                            <Label fx:id="leaderLabel" styleClass="stat-value stat-value-small" text="Nessuna"/>
                        </VBox>
                    </children>
                </HBox>
            </VBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
            </padding>
            <children>
                <TabPane styleClass="content-tabs" tabClosingPolicy="UNAVAILABLE">
                    <tabs>
                        <Tab text="Squadre">
                            <content>
                                <BorderPane styleClass="content-pane">
                                    <center>
                                        <SplitPane dividerPositions="0.42">
                                            <items>
                                                <VBox spacing="10.0" styleClass="table-panel">
                                                    <Label styleClass="section-title" text="Squadre registrate"/>
                                                    <Label styleClass="section-subtitle"
                                                           text="Seleziona una squadra per visualizzare la rosa completa." wrapText="true"/>
                                                    <TableView fx:id="squadreTable" VBox.vgrow="ALWAYS">
                                                        <columns>
                                                            <TableColumn fx:id="squadraNomeColumn" prefWidth="230.0" text="Nome squadra"/>
                                                            <TableColumn fx:id="squadraNumeroGiocatoriColumn" prefWidth="110.0" text="Giocatori"/>
                                                        </columns>
                                                    </TableView>
                                                </VBox>
                                                <VBox spacing="10.0" styleClass="table-panel">
                                                    <Label styleClass="section-title" text="Rosa selezionata"/>
                                                    <Label styleClass="section-subtitle"
                                                           text="Ogni squadra deve contenere esattamente cinque giocatori." wrapText="true"/>
                                                    <TableView fx:id="giocatoriTable" VBox.vgrow="ALWAYS">
                                                        <columns>
                                                            <TableColumn fx:id="giocatoreNomeColumn" prefWidth="170.0" text="Nome"/>
                                                            <TableColumn fx:id="giocatoreCognomeColumn" prefWidth="170.0" text="Cognome"/>
                                                            <TableColumn fx:id="giocatoreDataColumn" prefWidth="160.0" text="Data di nascita"/>
                                                        </columns>
                                                    </TableView>
                                                </VBox>
                                            </items>
                                        </SplitPane>
                                    </center>
                                    <bottom>
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="actions-bar">
                                            <Button mnemonicParsing="false" onAction="#handleNuovaSquadra" styleClass="primary-button"
                                                    text="Aggiungi squadra"/>
                                            <Button mnemonicParsing="false" onAction="#handleModificaSquadra" styleClass="secondary-button"
                                                    text="Modifica squadra"/>
                                        </HBox>
                                    </bottom>
                                </BorderPane>
                            </content>
                        </Tab>
                        <Tab text="Partite">
                            <content>
                                <BorderPane styleClass="content-pane">
                                    <center>
                                        <VBox spacing="10.0" styleClass="table-panel">
                                            <Label styleClass="section-title" text="Partite registrate"/>
                                            <Label styleClass="section-subtitle"
                                                   text="Ogni modifica ricalcola automaticamente la classifica corrente." wrapText="true"/>
                                            <TableView fx:id="partiteTable" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="partitaDataColumn" prefWidth="140.0" text="Data"/>
                                                    <TableColumn fx:id="partitaCasaColumn" prefWidth="220.0" text="Squadra casa"/>
                                                    <TableColumn fx:id="partitaGoalCasaColumn" prefWidth="90.0" text="Goal casa"/>
                                                    <TableColumn fx:id="partitaGoalOspiteColumn" prefWidth="90.0" text="Goal ospite"/>
                                                    <TableColumn fx:id="partitaOspiteColumn" prefWidth="220.0" text="Squadra ospite"/>
                                                </columns>
                                            </TableView>
                                        </VBox>
                                    </center>
                                    <bottom>
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="actions-bar">
                                            <Button mnemonicParsing="false" onAction="#handleNuovaPartita" styleClass="primary-button"
                                                    text="Aggiungi partita"/>
                                            <Button mnemonicParsing="false" onAction="#handleModificaPartita" styleClass="secondary-button"
                                                    text="Modifica partita"/>
                                            <Button mnemonicParsing="false" onAction="#handleRimuoviPartita" styleClass="danger-button"
                                                    text="Rimuovi partita"/>
                                        </HBox>
                                    </bottom>
                                </BorderPane>
                            </content>
                        </Tab>
                        <Tab text="Classifica">
                            <content>
                                <BorderPane styleClass="content-pane">
                                    <center>
                                        <VBox spacing="10.0" styleClass="table-panel">
                                            <Label styleClass="section-title" text="Classifica corrente"/>
                                            <Label styleClass="section-subtitle"
                                                   text="La classifica e ordinata in modo decrescente in base ai punti." wrapText="true"/>
                                            <TableView fx:id="classificaTable" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="classificaPosizioneColumn" prefWidth="90.0" text="Posizione"/>
                                                    <TableColumn fx:id="classificaSquadraColumn" prefWidth="330.0" text="Squadra"/>
                                                    <TableColumn fx:id="classificaPuntiColumn" prefWidth="120.0" text="Punti"/>
                                                </columns>
                                            </TableView>
                                        </VBox>
                                    </center>
                                </BorderPane>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox spacing="8.0" styleClass="status-bar">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="12.0"/>
            </padding>
            <Label styleClass="status-label" text="Stato"/>
            <Label fx:id="statoLabel" styleClass="status-value" text="Pronto"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label styleClass="status-hint" text="Suggerimento: salva l'archivio dopo le modifiche importanti."/>
        </HBox>
    </bottom>
</BorderPane>
